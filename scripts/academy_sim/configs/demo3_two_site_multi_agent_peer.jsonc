{
  "run_id": "academy-sim-demo3",
  "task": "Use a single-agent planner and a multi-agent ChemGraph executor over Globus exchange.",
  "initial_graph": "planner",
  "bootstrap_mode": "manual",
  "exchange": {
    "type": "http",
    "registration": "exchange",
    "url": "https://exchange.academy-agents.org/v1",
    "namespace": "academy-sim-demo3"
  },
  "artifacts": {
    "run_dir": "./runs"
  },
  "model": {
    "config_file": "lm_config.json"
  },
  "graphs": {
    "planner": {
      "site": "aurora",
      "workflow_type": "single_agent",
      "startup_prompt": "Ask the executor graph to decompose and run a water calculation, then send back a concise result.",
      "system_prompt": "You are the site planner. Delegate scientific execution to executor.",
      "allowed_peers": [
        "executor"
      ],
      "science_tools": [],
      "peer_tools": {
        "enabled": true
      },
      "idle_timeout_s": 60.0
    },
    "executor": {
      "site": "local-or-crux",
      "workflow_type": "multi_agent",
      "startup_prompt": null,
      "planner_prompt": "You are the internal ChemGraph planner for the executor graph. Decompose peer requests into tool-using executor tasks.",
      "executor_prompt": "You are the internal ChemGraph executor. Use available MCP tools to run chemistry tasks.",
      "allowed_peers": [
        "planner"
      ],
      "science_tools": [
        {
          "source": "mcp",
          "name": "chemgraph-general",
          "transport": "streamable_http",
          "url": "http://127.0.0.1:9003/mcp/",
          "allowed_tools": [
            "molecule_name_to_smiles",
            "smiles_to_coordinate_file",
            "run_ase",
            "extract_output_json"
          ]
        }
      ],
      "peer_tools": {
        "enabled": true
      },
      "idle_timeout_s": 60.0
    }
  }
}
